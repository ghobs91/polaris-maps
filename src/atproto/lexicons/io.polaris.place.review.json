{
  "lexicon": 1,
  "id": "io.polaris.place.review",
  "defs": {
    "main": {
      "type": "record",
      "description": "A review of a place / POI.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["subject", "rating", "createdAt"],
        "properties": {
          "subject": {
            "type": "object",
            "required": ["poiUuid", "source"],
            "properties": {
              "poiUuid": { "type": "string" },
              "source": { "type": "string", "description": "'osm' | 'overture' | 'polaris'" },
              "osmId": { "type": "string" },
              "overtureId": { "type": "string" },
              "name": { "type": "string" },
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
          "text": { "type": "string", "maxGraphemes": 2000 },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
