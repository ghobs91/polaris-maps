{
  "name": "polaris-maps",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.js",
    "test:contract": "jest --config jest.contract.config.js",
    "test:e2e:ios": "detox test --configuration ios.sim.release",
    "test:e2e:android": "detox test --configuration android.emu.release",
    "test:benchmark": "jest --config jest.benchmark.config.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "prebuild": "expo prebuild --clean",
    "prepare": "husky"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@expo/vector-icons": "^14.0.0",
    "@maplibre/maplibre-react-native": "^10.0.0-alpha.2",
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.8.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-community/slider": "^4.5.5",
    "@react-navigation/bottom-tabs": "^7.3.0",
    "@react-navigation/native": "^7.1.0",
    "babel-preset-expo": "~12.0.0",
    "expo": "~52.0.0",
    "expo-asset": "^55.0.9",
    "expo-blur": "^55.0.8",
    "expo-camera": "~16.0.0",
    "expo-constants": "~17.0.0",
    "expo-crypto": "^14.0.2",
    "expo-file-system": "^18.0.12",
    "expo-font": "~13.0.0",
    "expo-image-manipulator": "^13.0.6",
    "expo-keep-awake": "~14.0.3",
    "expo-linking": "~7.0.0",
    "expo-location": "~18.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-sqlite": "~15.1.4",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.0",
    "expo-web-browser": "~14.0.0",
    "gun": "^0.2020.1240",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-get-random-values": "^2.0.0",
    "react-native-mmkv": "^3.2.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@react-native-community/cli": "latest",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "prettier": "^3.4.0",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.6.0"
  }
