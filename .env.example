# Traffic Flow API Keys
# Get your free TomTom key at https://developer.tomtom.com/
EXPO_PUBLIC_TOMTOM_API_KEY=your_tomtom_api_key_here
# Get your free HERE key at https://developer.here.com/
EXPO_PUBLIC_HERE_API_KEY=your_here_api_key_here
# Generate at https://developer.apple.com/account/resources/authkeys/list
# Create a MapKit JS key, then generate a JWT token with it.
EXPO_PUBLIC_APPLE_MAPKIT_TOKEN=your_apple_mapkit_token_here
# Optional helpers for pnpm mapkit:token
APPLE_TEAM_ID=your_apple_team_id_here
APPLE_KEY_ID=your_apple_key_id_here
APPLE_MAPKIT_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8

# Overture Maps Places proxy (run: pnpm overture-proxy)
# See backend/overture-proxy.mjs — queries Overture S3 GeoParquet via DuckDB.
EXPO_PUBLIC_OVERTURE_PLACES_URL=http://localhost:4100/v1/places
